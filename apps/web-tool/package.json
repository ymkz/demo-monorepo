{
  "name": "web-tool",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "wireit",
    "build": "wireit",
    "typecheck": "wireit",
    "start": "node dist/rsc/index.js"
  },
  "wireit": {
    "dev": {
      "command": "vite dev --port 4000",
      "service": true
    },
    "build": {
      "command": "vite build --app"
    },
    "typecheck": {
      "command": "tsc --noEmit"
    }
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "react": "catalog:",
    "react-dom": "catalog:",
    "spiceflow": "catalog:",
    "tailwindcss": "^4.0.6",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "^6.0.1",
    "vite": "^8.0.0"
  }
}
