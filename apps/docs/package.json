{
  "name": "@demo/docs",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wireit",
    "build": "wireit",
    "check": "wireit",
    "typecheck": "wireit",
    "start": "next start",
    "check:fix": "biome check --write ."
  },
  "wireit": {
    "dev": {
      "command": "next dev -p 5000",
      "service": true
    },
    "build": {
      "command": "next build",
      "files": [
        "src/**/*",
        "app/**/*",
        "content/**/*",
        "next.config.ts"
      ],
      "output": [
        ".next/**"
      ]
    },
    "check": {
      "command": "biome check .",
      "files": [
        "src/**/*",
        "app/**/*",
        "content/**/*"
      ]
    },
    "typecheck": {
      "command": "tsc --noEmit",
      "files": [
        "src/**/*",
        "app/**/*",
        "content/**/*"
      ]
    }
  },
  "dependencies": {
    "next": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "fumadocs-core": "catalog:",
    "fumadocs-ui": "catalog:",
    "fumadocs-mdx": "catalog:",
    "mermaid": "^11.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "typescript": "catalog:",
    "wireit": "catalog:"
  }
}
